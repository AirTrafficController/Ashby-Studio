# Copy this file to .env and fill in your own values.
# .env is gitignored — never commit real keys.

# Anthropic API key for AI-assisted wizard prefill.
# Get one at https://console.anthropic.com (API Keys -> Create Key).
# NOTE: a VITE_-prefixed var is bundled into the client and visible in the
# browser. This is acceptable for LOCAL demos only. For any public deploy,
# route calls through a server-side proxy instead.
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here
